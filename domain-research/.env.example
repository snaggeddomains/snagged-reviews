# ---- Required: the AI "brain" ----
OPENAI_API_KEY=sk-...
# Any chat model with tool/function calling. Override if you prefer another.
OPENAI_MODEL=gpt-4o

# ---- Optional premium data sources ----
# Each source only appears to the AI when its keys are present.

# WhoisXML API (https://whoisxmlapi.com) — current + historical WHOIS
WHOISXML_API_KEY=

# DomainIQ — paste YOUR exact endpoint as a template.
# {domain} and {key} are substituted (domain is URL-encoded for you).
# Example:
# DOMAINIQ_URL_TEMPLATE=https://www.domainiq.com/api?key={key}&service=whois&domain={domain}&format=json
DOMAINIQ_URL_TEMPLATE=
DOMAINIQ_API_KEY=

# BigDomainData — same template approach.
# Example:
# BIGDOMAINDATA_URL_TEMPLATE=https://api.bigdomaindata.com/?key={key}&domain={domain}
BIGDOMAINDATA_URL_TEMPLATE=
BIGDOMAINDATA_API_KEY=
